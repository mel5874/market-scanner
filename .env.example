# Comma-separated Yahoo Finance symbols. Crypto uses Yahoo suffixes such as BTC-USD.
WATCHLIST=AAPL,MSFT,NVDA,SPY,BTC-USD,ETH-USD
DATA_PERIOD=6mo
DATA_INTERVAL=1d
MIN_SCORE_TO_ALERT=55
PAPER_STARTING_CASH=25000
MAX_POSITION_PCT=0.10
MAX_TRADE_RISK_PCT=0.01
MAX_TRADE_RISK_DOLLARS=250
MAX_DAILY_PAPER_RISK_PCT=0.03
MAX_OPEN_PAPER_POSITIONS=5
TRADING_MODE=paper
LOG_PATH=logs/market_scanner.log
DATABASE_PATH=data/market_scanner.sqlite
CSV_LOG_PATH=logs/signals.csv

# Email alerts (optional). Never commit real secrets.
EMAIL_ALERTS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# Telegram alerts (optional). Never commit real secrets.
TELEGRAM_ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord alerts (optional). Never commit real secrets.
DISCORD_ALERTS_ENABLED=false
DISCORD_WEBHOOK_URL=

# Safety note: this project does not support live trading. Do not add broker execution credentials.
# Setting LIVE_TRADING_ENABLED=true or ENABLE_ORDER_EXECUTION=true will cause startup to fail.
